************************************************************************
* DATA
************************************************************************
DATA: go_model TYPE REF TO lcl_model,
      go_view  TYPE REF TO lcl_view.

************************************************************************
* Step 4: AT SELECTION-SCREEN
* Call static validation methods to validate screen inputs
************************************************************************
AT SELECTION-SCREEN.
  lcl_model=>validate_material_input(
    it_matnr = s_matnr[] ).

  lcl_model=>validate_created_on_input(
    it_ersda = s_ersda[] ).

  lcl_model=>validate_plant_input(
    iv_werks = p_werks ).

************************************************************************
* Step 6: START-OF-SELECTION
* Create model instance, call data retrieval method
* Step 8: Create view instance, call WRITE or ALV based on radio button
************************************************************************
START-OF-SELECTION.
  " Step 6: Create model instance and retrieve data
  CREATE OBJECT go_model.
  go_model->get_data(
    it_matnr = s_matnr[]
    it_ersda = s_ersda[]
    iv_werks = p_werks
    iv_hili  = COND abap_bool(
                 WHEN p_hili = 'X' THEN abap_true
                 ELSE abap_false ) ).

  " Step 8: Create view instance and display
  CREATE OBJECT go_view.

  IF p_writ = 'X'.
    go_view->display_write( ).
  ELSE.
    go_view->display_alv( ).
  ENDIF.

