         plant          TYPE mcha-werks,        " Col 2
         plant_name     TYPE t001w-name1,       " Col 3
         batch          TYPE mcha-charg,        " Col 4
         created_on     TYPE char10,            " Col 5: MM/DD/YYYY format
         created_by     TYPE mcha-ernam,        " Col 6
         changed_on     TYPE char10,            " Col 7: MM/DD/YYYY format
         changed_by     TYPE mcha-aenam,        " Col 8
         material_type  TYPE mara-mtart,        " Col 9
         valuation_type TYPE mcha-bwtar,        " Col 10
         material_group TYPE mara-matkl,        " Col 11
         industry_sector TYPE mara-mbrsh,       " Col 12
         gross_weight   TYPE mara-brgew,        " Col 13
         net_weight     TYPE mara-ntgew,        " Col 14
         unit_weight    TYPE mara-gewei,        " Col 15
         volume         TYPE mara-volum,        " Col 16
         volume_unit    TYPE mara-voleh,        " Col 17
         supplier       TYPE mcha-lifnr,        " Col 18
         goods_receipt  TYPE char10,            " Col 19: MM/DD/YYYY format
