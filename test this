REPORT yn3151367_mmr_matrep.
" Step 1: Program YN3151367_MMR_MATREP
" Title: Material Master Report - Batch View
" Type: Executable Program | Package: $tmp

TABLES: mara,
        mcha.

************************************************************************
* TEXT ELEMENTS TO MAINTAIN IN SE38
************************************************************************
* TEXT-T01 = Criteria:
* TEXT-T02 = Select a View:
*
* TEXT-E01 = Invalid Material
* TEXT-E02 = Date specified is in the future, enter a valid date
* TEXT-E03 = Invalid Plant
* TEXT-E04 = No data found
*
* TEXT-H01 = Material Master Report
* TEXT-H02 = Material Batch View
*
* TEXT-C01 = Material
* TEXT-C02 = Plant
* TEXT-C03 = Plant Name
* TEXT-C04 = Batch
* TEXT-C05 = Created On
* TEXT-C06 = Created By
* TEXT-C07 = Changed On
* TEXT-C08 = Changed By
* TEXT-C09 = Material Type
* TEXT-C10 = Valuation Type
* TEXT-C11 = Material Group
* TEXT-C12 = Industry Sector
* TEXT-C13 = Gross Weight
* TEXT-C14 = Net Weight
* TEXT-C15 = Unit of Weight
* TEXT-C16 = Volume
* TEXT-C17 = Volume Unit
* TEXT-C18 = Supplier
* TEXT-C19 = Goods Receipt
* TEXT-C20 = Country
*
* SELECTION TEXTS:
* S_MATNR  = (Dictionary Reference checked)
* S_ERSDA  = (Dictionary Reference checked)
* P_WERKS  = (Dictionary Reference checked)
* RB_WRITE = Display report with WRITE
* RB_ALV   = Display report as ALV
* CB_HOTSP = Enable Hotspot on Material

************************************************************************
* NOTE ON TABLE FIELD LOCATIONS
************************************************************************
* The instructions say get BRGEW, NTGEW, GEWEI, VOLUM, VOLEH from MCHA.
* However these fields don't exist in MCHA in our training system.
* Verified each field in SE11 — they are in MARA.
* SELECT retrieves them as mara~brgew, mara~ntgew, etc.
*
* Corrected source tables:
*   MARA: MATNR, MTART, MATKL, MBRSH, BRGEW, NTGEW, GEWEI, VOLUM, VOLEH
*   MCHA: WERKS, CHARG, ERSDA, ERNAM, LAEDA, AENAM, BWTAR, LIFNR, LWEDT, HERKL

************************************************************************
* TYPES
************************************************************************
TYPES: gty_r_matnr TYPE RANGE OF mara-matnr,
       gty_r_ersda TYPE RANGE OF mcha-ersda.

" Step 5b: Structure for JOIN result (MARA + MCHA)
TYPES: BEGIN OF gty_raw,
         matnr TYPE mara-matnr,
         mtart TYPE mara-mtart,
         matkl TYPE mara-matkl,
         mbrsh TYPE mara-mbrsh,
         brgew TYPE mara-brgew,      " In MARA, not MCHA (verified SE11)
         ntgew TYPE mara-ntgew,      " In MARA, not MCHA (verified SE11)
         gewei TYPE mara-gewei,      " In MARA, not MCHA (verified SE11)
         volum TYPE mara-volum,      " In MARA, not MCHA (verified SE11)
         voleh TYPE mara-voleh,      " In MARA, not MCHA (verified SE11)
         werks TYPE mcha-werks,
         charg TYPE mcha-charg,
         ersda TYPE mcha-ersda,
         ernam TYPE mcha-ernam,
         laeda TYPE mcha-laeda,
         aenam TYPE mcha-aenam,
         bwtar TYPE mcha-bwtar,
         lifnr TYPE mcha-lifnr,
         lwedt TYPE mcha-lwedt,
         herkl TYPE mcha-herkl,
       END OF gty_raw.
TYPES gty_tt_raw TYPE STANDARD TABLE OF gty_raw WITH DEFAULT KEY.

" Step 5d: Structure for MAKT material description lookup
TYPES: BEGIN OF gty_makt,
         matnr TYPE makt-matnr,
         maktx TYPE makt-maktx,
       END OF gty_makt.
TYPES gty_tt_makt TYPE STANDARD TABLE OF gty_makt WITH DEFAULT KEY.

" Step 5e: Structure for T001W plant name lookup
TYPES: BEGIN OF gty_t001w,
         werks TYPE t001w-werks,
         name1 TYPE t001w-name1,
       END OF gty_t001w.
TYPES gty_tt_t001w TYPE STANDARD TABLE OF gty_t001w WITH DEFAULT KEY.

" Step 5f: Final output structure - all 20 columns per Report Fields table
"   Col 1:  MATERIAL        = MATNR concatenated with MAKTX
"   Col 2:  PLANT           = WERKS (MCHA)
"   Col 3:  PLANT_NAME      = NAME1 (T001W)
"   Col 4:  BATCH           = CHARG (MCHA)
"   Col 5:  CREATED_ON      = ERSDA (MCHA) MM/DD/YYYY
"   Col 6:  CREATED_BY      = ERNAM (MCHA)
"   Col 7:  CHANGED_ON      = LAEDA (MCHA) MM/DD/YYYY
"   Col 8:  CHANGED_BY      = AENAM (MCHA)
"   Col 9:  MATERIAL_TYPE   = MTART (MARA)
"   Col 10: VALUATION_TYPE  = BWTAR (MCHA)
"   Col 11: MATERIAL_GROUP  = MATKL (MARA)
"   Col 12: INDUSTRY_SECTOR = MBRSH (MARA)
"   Col 13: GROSS_WEIGHT    = BRGEW (MARA)
"   Col 14: NET_WEIGHT      = NTGEW (MARA)
"   Col 15: UNIT_WEIGHT     = GEWEI (MARA)
"   Col 16: VOLUME          = VOLUM (MARA)
"   Col 17: VOLUME_UNIT     = VOLEH (MARA)
"   Col 18: SUPPLIER        = LIFNR (MCHA)
"   Col 19: GOODS_RECEIPT   = LWEDT (MCHA) MM/DD/YYYY
"   Col 20: COUNTRY         = HERKL (MCHA)
TYPES: BEGIN OF gty_final,
         material        TYPE mara-matnr,
         plant           TYPE mcha-werks,
         plant_name      TYPE t001w-name1,
         batch           TYPE mcha-charg,
         created_on      TYPE char10,
         created_by      TYPE mcha-ernam,
         changed_on      TYPE char10,
         changed_by      TYPE mcha-aenam,
         material_type   TYPE mara-mtart,
         valuation_type  TYPE mcha-bwtar,
         material_group  TYPE mara-matkl,
         industry_sector TYPE mara-mbrsh,
         gross_weight    TYPE mara-brgew,
         net_weight      TYPE mara-ntgew,
         unit_weight     TYPE mara-gewei,
         volume          TYPE mara-volum,
         volume_unit     TYPE mara-voleh,
         supplier        TYPE mcha-lifnr,
         goods_receipt   TYPE char10,
         country         TYPE mcha-herkl,
         cell_color      TYPE lvc_t_scol,
       END OF gty_final.
TYPES gty_tt_final TYPE STANDARD TABLE OF gty_final WITH DEFAULT KEY.

