TYPES: BEGIN OF ty_final,
         material TYPE string,      " Concatenated Material - Description
         matnr    TYPE matnr,       " Hidden field for Hotspot MM03 call
         werks    TYPE mcha-werks,
         name1    TYPE t001w-name1,
         charg    TYPE mcha-charg,
         ersda    TYPE string,      " Formatted to MM/DD/YYYY
         ernam    TYPE mcha-ernam,
         laeda    TYPE string,      " Formatted to MM/DD/YYYY
         aenam    TYPE mcha-aenam,
         mtart    TYPE mara-mtart,
         bwtar    TYPE mcha-bwtar,
         matkl    TYPE mara-matkl,
         mbrsh    TYPE mara-mbrsh,
         brgew    TYPE mara-brgew,
         ntgew    TYPE mara-ntgew,
         gewei    TYPE mara-gewei,
         volum    TYPE mara-volum,
         voleh    TYPE mara-voleh,
         lifnr    TYPE mcha-lifnr,
         lwedt    TYPE string,      " Formatted to MM/DD/YYYY
         herkl    TYPE mcha-herkl,
         t_color  TYPE lvc_t_scol,  " For Green column color
       END OF ty_final.
TYPES: tty_final TYPE STANDARD TABLE OF ty_final.
DATA: gt_final TYPE tty_final.

" Dummy variables for Selection Screen
DATA: gv_matnr TYPE mara-matnr,
      gv_ersda TYPE mcha-ersda.

----------------------------------------------------------------------
* SELECTION SCREEN
----------------------------------------------------------------------
SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME TITLE TEXT-t01.
  SELECT-OPTIONS: s_matnr FOR gv_matnr,
                  s_ersda FOR gv_ersda.
  PARAMETERS:     p_werks TYPE mcha-werks.
SELECTION-SCREEN END OF BLOCK b1.

SELECTION-SCREEN BEGIN OF BLOCK b2 WITH FRAME TITLE TEXT-t02.
  PARAMETERS: p_write RADIOBUTTON GROUP rb1,
              p_alv   RADIOBUTTON GROUP rb1 DEFAULT 'X'.
  SELECTION-SCREEN SKIP 1.
  PARAMETERS: p_hot AS CHECKBOX DEFAULT 'X'.
SELECTION-SCREEN END OF BLOCK b2.

----------------------------------------------------------------------
* CLASS DEFINITIONS (MVC Pattern)
----------------------------------------------------------------------
CLASS lcl_model DEFINITION.
  PUBLIC SECTION.
    CLASS-METHODS:
      validate_material IMPORTING it_matnr TYPE rseloption,
      validate_date     IMPORTING it_ersda TYPE rseloption,
      validate_plant    IMPORTING iv_werks TYPE werks_d.

    METHODS:
      get_data IMPORTING it_matnr        TYPE rseloption
                         it_ersda        TYPE rseloption
                         iv_werks        TYPE werks_d
               EXPORTING et_final_output TYPE STANDARD TABLE.
ENDCLASS. 

CLASS lcl_view DEFINITION.
  PUBLIC SECTION.
    METHODS:
      display_write IMPORTING it_final TYPE tty_final,
      display_alv   IMPORTING it_final TYPE tty_final.
      
    METHODS:
      on_link_click FOR EVENT link_click OF cl_salv_events_table
        IMPORTING row column.
        
  PRIVATE SECTION.
    DATA: mt_final TYPE TABLE OF ty_final. 
ENDCLASS.

----------------------------------------------------------------------
* CLASS IMPLEMENTATIONS
----------------------------------------------------------------------
CLASS lcl_model IMPLEMENTATION.
  METHOD validate_material.
    IF it_matnr IS NOT INITIAL.
      SELECT UP TO 1 ROWS matnr FROM mara INTO @DATA(lv_matnr) WHERE matnr IN @it_matnr. ENDSELECT.
      IF sy-subrc <> 0.
        MESSAGE 'Invalid Material' TYPE 'S' DISPLAY LIKE 'E'.
      ENDIF.
    ENDIF.
  ENDMETHOD.

  METHOD validate_date.
    IF it_ersda IS NOT INITIAL.
      LOOP AT it_ersda INTO DATA(ls_ersda) WHERE high > sy-datum OR ( low > sy-datum AND high IS INITIAL ).
        MESSAGE 'Date specified is in the future, enter a valid date' TYPE 'S' DISPLAY LIKE 'E'.
        EXIT.52
      ENDLOOP.
    ENDIF.
  ENDMETHOD.

  METHOD validate_plant.
    IF iv_werks IS NOT INITIAL.
      SELECT SINGLE werks FROM t001w INTO @DATA(lv_werks) WHERE werks = @iv_werks.
      IF sy-subrc <> 0.
        MESSAGE 'Invalid Plant' TYPE 'S' DISPLAY LIKE 'E'.
      ENDIF.
    ENDIF.
  ENDMETHOD.

  METHOD get_data.
    " Convert Plant Parameter to Range Table for flexible SELECT
    DATA(lt_werks_range) = VALUE rseloption( ( sign = 'I' option = 'EQ' low = iv_werks ) ).

    " Main Selection using JOIN
    SELECT a~matnr, a~mtart, a~matkl, a~mbrsh,
           a~brgew, a~ntgew, a~gewei, a~volum, a~voleh, 
           b~werks, b~charg, b~ersda, b~ernam, b~laeda, b~aenam, b~bwtar, 
           b~lifnr, b~lwedt, b~herkl
      FROM mara AS a
      INNER JOIN mcha AS b ON a~matnr = b~matnr
      INTO TABLE @DATA(lt_mara_mcha)
      WHERE a~matnr IN @it_matnr
        AND b~ersda IN @it_ersda
        AND b~werks IN @lt_werks_range.

    IF lt_mara_mcha IS INITIAL.
      MESSAGE 'No data found.' TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.

    SORT lt_mara_mcha BY matnr charg.

    " FOR ALL ENTRIES for Texts and Plant Names
    SELECT matnr, maktx FROM makt INTO TABLE @DATA(lt_makt)
      FOR ALL ENTRIES IN @lt_mara_mcha
      WHERE matnr = @lt_mara_mcha-matnr AND spras = @sy-langu.
    SORT lt_makt BY matnr.

    SELECT werks, name1 FROM t001w INTO TABLE @DATA(lt_t001w)
      FOR ALL ENTRIES IN @lt_mara_mcha
      WHERE werks = @lt_mara_mcha-werks.
    SORT lt_t001w BY werks.

    " Populate Final Output Table
    DATA: ls_final TYPE ty_final.
    LOOP AT lt_mara_mcha INTO DATA(ls_mcha).
      CLEAR ls_final.
      MOVE-CORRESPONDING ls_mcha TO ls_final.
      
      " Format Dates dynamically to MM/DD/YYYY
      IF ls_mcha-ersda IS NOT INITIAL. ls_final-ersda = |{ ls_mcha-ersda+4(2) }/{ ls_mcha-ersda+6(2) }/{ ls_mcha-ersda(4) }|. ENDIF.
      IF ls_mcha-laeda IS NOT INITIAL. ls_final-laeda = |{ ls_mcha-laeda+4(2) }/{ ls_mcha-laeda+6(2) }/{ ls_mcha-laeda(4) }|. ENDIF.
      IF ls_mcha-lwedt IS NOT INITIAL. ls_final-lwedt = |{ ls_mcha-lwedt+4(2) }/{ ls_mcha-lwedt+6(2) }/{ ls_mcha-lwedt(4) }|. ENDIF.

      " Append Descriptions
      READ TABLE lt_makt INTO DATA(ls_makt) WITH KEY matnr = ls_mcha-matnr BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final-material = |{ ls_mcha-matnr } - { ls_makt-maktx }|.
      ELSE.
        ls_final-material = ls_mcha-matnr.
      ENDIF.

      READ TABLE lt_t001w INTO DATA(ls_t001w) WITH KEY werks = ls_mcha-werks BINARY SEARCH.
      IF sy-subrc = 0. ls_final-name1 = ls_t001w-name1. ENDIF.

      " Set GREEN color for Material column
      ls_final-t_color = VALUE #( ( fname = 'MATERIAL' color-col = 5 color-int = 0 color-inv = 0 ) ).

      APPEND ls_final TO et_final_output.
    ENDLOOP.
  ENDMETHOD.
ENDCLASS.

CLASS lcl_view IMPLEMENTATION.
  METHOD display_write.
    WRITE: / 'Material', 40 'Plant', 50 'Plant Name', 80 'Batch', 100 'Created On'.
    ULINE.
    LOOP AT it_final INTO DATA(ls_final).
      WRITE: / ls_final-material(35), 40 ls_final-werks, 50 ls_final-name1(25), 80 ls_final-charg, 100 ls_final-ersda.
    ENDLOOP.
  ENDMETHOD.

  METHOD display_alv.
    DATA: lo_alv     TYPE REF TO cl_salv_table,
          lo_columns TYPE REF TO cl_salv_columns_table,
          lo_column  TYPE REF TO cl_salv_column_table,
          lo_events  TYPE REF TO cl_salv_events_table,
          lo_sorts   TYPE REF TO cl_salv_sorts.

    mt_final = it_final.

    TRY.
        cl_salv_table=>factory( IMPORTING r_salv_table = lo_alv CHANGING t_table = mt_final ).

        " ALV Formatting
        lo_alv->get_functions( )->set_default( abap_true ).
        lo_alv->get_display_settings( )->set_striped_pattern( abap_true ).
        
        lo_columns = lo_alv->get_columns( ).
        lo_columns->set_optimize( abap_true ).
        lo_columns->set_color_column( 'T_COLOR' ).

        " Hide raw MATNR field
        lo_column ?= lo_columns->get_column( 'MATNR' ).
        lo_column->set_visible( abap_false ).

        " Rename Concatenated Material Column
        lo_column ?= lo_columns->get_column( 'MATERIAL' ).
        lo_column->set_short_text( 'Material' ).
        lo_column->set_long_text( 'Material - Description' ).
        
        " Enable Hotspot if checked
        IF p_hot = abap_true.
          lo_column->set_cell_type( if_salv_c_cell_type=>hotspot ).
          lo_events = lo_alv->get_event( ).
          SET HANDLER me->on_link_click FOR lo_events.
        ENDIF.

        " Sorting Logic
        lo_sorts = lo_alv->get_sorts( ).
        lo_sorts->add_sort( columnname = 'MATERIAL' position = 1 sequence = if_salv_c_sort=>sort_up ).
        lo_sorts->add_sort( columnname = 'WERKS'    position = 2 sequence = if_salv_c_sort=>sort_up ).
        lo_sorts->add_sort( columnname = 'CHARG'    position = 3 sequence = if_salv_c_sort=>sort_up ).
        lo_sorts->add_sort( columnname = 'ERSDA'    position = 4 sequence = if_salv_c_sort=>sort_down ).

        " Top of Page Formatting
        DATA(lo_header) = NEW cl_salv_form_layout_grid( ).
        lo_header->create_header_information( row = 1 column = 1 text = 'Material Master Report' ).
        lo_header->create_label( row = 2 column = 1 text = 'Material Batch View' ).
        lo_header->create_text(  row = 3 column = 1 text = |Executed by: { sy-uname }| ).
        DATA(lv_time) = |{ sy-datum+4(2) }/{ sy-datum+6(2) }/{ sy-datum(4) } - { sy-uzeit(2) }:{ sy-uzeit+2(2) }:{ sy-uzeit+4(2) }|.
        lo_header->create_text(  row = 4 column = 1 text = |Executed on: { lv_time }| ).
        lo_alv->set_top_of_list( lo_header ).

        lo_alv->display( ).

      CATCH cx_root.
        MESSAGE 'ALV Error occurred' TYPE 'E'.
    ENDTRY.
  ENDMETHOD.

  METHOD on_link_click.
    READ TABLE mt_final INTO DATA(ls_row) INDEX row.
    IF sy-subrc = 0.
      SET PARAMETER ID 'MAT' FIELD ls_row-matnr. 
      CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
    ENDIF.
  ENDMETHOD.
ENDCLASS.


  ----------------------------------------------------------------------
* EVENT BLOCKS
----------------------------------------------------------------------
AT SELECTION-SCREEN.
  " Convert Select-Options to RSELOPTION structure before passing
  DATA(lt_matnr_rsel) = VALUE rseloption( FOR ls_m IN s_matnr[] ( sign = ls_m-sign option = ls_m-option low = ls_m-low high = ls_m-high ) ).
  DATA(lt_ersda_rsel) = VALUE rseloption( FOR ls_e IN s_ersda[] ( sign = ls_e-sign option = ls_e-option low = ls_e-low high = ls_e-high ) ).

  lcl_model=>validate_material( lt_matnr_rsel ).
  lcl_model=>validate_date( lt_ersda_rsel ).
  lcl_model=>validate_plant( p_werks ).

START-OF-SELECTION.
  DATA(lo_model) = NEW lcl_model( ).
  DATA(lo_view)  = NEW lcl_view( ).

  " Convert again for the main data retrieval
  DATA(lt_mat_data) = VALUE rseloption( FOR ls_m IN s_matnr[] ( sign = ls_m-sign option = ls_m-option low = ls_m-low high = ls_m-high ) ).
  DATA(lt_ers_data) = VALUE rseloption( FOR ls_e IN s_ersda[] ( sign = ls_e-sign option = ls_e-option low = ls_e-low high = ls_e-high ) ).

  lo_model->get_data(
    EXPORTING it_matnr = lt_mat_data
              it_ersda = lt_ers_data
              iv_werks = p_werks
    IMPORTING et_final_output = gt_final ).

  IF p_write = abap_true.
    lo_view->display_write( gt_final ).
  ELSE.
    lo_view->display_alv( gt_final ).
  ENDIF.
