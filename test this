************************************************************************
* Step 4: AT SELECTION-SCREEN
* Call static validation methods to validate screen inputs
************************************************************************
AT SELECTION-SCREEN.
  lcl_model=>validate_material_input(
    it_matnr = s_matnr[] ).

  lcl_model=>validate_created_on_input(
    it_ersda = s_ersda[] ).

  lcl_model=>validate_plant_input(
    iv_werks = p_werks ).

************************************************************************
* Step 6 + 8: START-OF-SELECTION
* Step 6: Create model instance, call data retrieval method
* Step 8: Create view instance, call WRITE or ALV based on radio button
************************************************************************
START-OF-SELECTION.
  " Step 6: Create model instance and retrieve data
  DATA(lo_model) = NEW lcl_model( ).
  lo_model->get_data(
    it_matnr = s_matnr[]
    it_ersda = s_ersda[]
    iv_werks = p_werks
    iv_hili  = COND abap_bool(
                 WHEN cb_hotsp = 'X' THEN abap_true
                 ELSE abap_false ) ).

  " 9j: Don't display if no data
  CHECK lcl_model=>gt_final IS NOT INITIAL.

  " Step 8: Create view instance and display
  DATA(lo_view) = NEW lcl_view( ).

  IF rb_write = abap_true.
    lo_view->display_write(
      it_final = lcl_model=>gt_final ).
  ELSE.
    lo_view->display_alv(
      EXPORTING
        iv_hotspot = COND #( WHEN cb_hotsp = abap_true THEN abap_true ELSE abap_false )
      CHANGING
        ct_final = lcl_model=>gt_final ).
  ENDIF.
