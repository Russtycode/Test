************************************************************************
* HELPER CLASS IMPLEMENTATION
* Converts dates to MM/DD/YYYY (required for columns 5, 7, 19)
* Converts time to HH:MM:SS military format (required for Step 9b)
************************************************************************
CLASS lcl_util IMPLEMENTATION.
  METHOD format_date_mdy.
    CLEAR rv_text.
    IF iv_date IS INITIAL.
      RETURN.
    ENDIF.

    rv_text = |{ iv_date+4(2) }/{ iv_date+6(2) }/{ iv_date+0(4) }|.

    IF rv_text+0(1) = '0'.
      SHIFT rv_text LEFT BY 1 PLACES.
    ENDIF.

    IF rv_text+2(1) = '/' AND rv_text+3(1) = '0'.
      rv_text = |{ rv_text+0(3) }{ rv_text+4 }|.
    ELSEIF rv_text+1(1) = '/' AND rv_text+2(1) = '0'.
      rv_text = |{ rv_text+0(2) }{ rv_text+3 }|.
    ENDIF.
  ENDMETHOD.

  METHOD format_time_military.
    CLEAR rv_text.
    IF iv_time IS INITIAL.
      RETURN.
    ENDIF.

    rv_text = |{ iv_time+0(2) }:{ iv_time+2(2) }:{ iv_time+4(2) }|.
  ENDMETHOD.
ENDCLASS.


************************************************************************
* MODEL CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_model IMPLEMENTATION.

  " Step 3a: Validate Material Input
  " Check if value exists in MARA. If not, error 'Invalid Material'.
  " Selection screen stays visible (MESSAGE TYPE 'E').
  " No validation when no value entered.
  METHOD validate_material_input.
    DATA lv_matnr TYPE mara-matnr.
    FIELD-SYMBOLS <fs_matnr> LIKE LINE OF it_matnr.

    LOOP AT it_matnr ASSIGNING <fs_matnr>.
      CHECK <fs_matnr>-sign = 'I'.

      CASE <fs_matnr>-option.
        WHEN 'EQ'.
          IF <fs_matnr>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr = @<fs_matnr>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'BT'.
          IF <fs_matnr>-low IS NOT INITIAL
             AND <fs_matnr>-high IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr BETWEEN @<fs_matnr>-low AND @<fs_matnr>-high.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'CP'.
          IF <fs_matnr>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr LIKE @<fs_matnr>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN OTHERS.
          IF <fs_matnr>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr = @<fs_matnr>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.
      ENDCASE.
    ENDLOOP.
  ENDMETHOD.

  " Step 3b: Validate Created On Input
  " Check if value > sy-datum (current date). If so, error message.
  " Checks both LOW and HIGH values of the range.
  METHOD validate_created_on_input.
    DATA ls_ersda LIKE LINE OF it_ersda.

    LOOP AT it_ersda INTO ls_ersda.
      IF ls_ersda-low IS NOT INITIAL AND ls_ersda-low > sy-datum.
        MESSAGE text-e02 TYPE 'E'.
      ENDIF.

      IF ls_ersda-high IS NOT INITIAL AND ls_ersda-high > sy-datum.
        MESSAGE text-e02 TYPE 'E'.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.

  " Step 3c: Validate Plant Input
  " Check if value exists in T001W. If not, error 'Invalid Plant'.
  METHOD validate_plant_input.
    DATA lv_werks TYPE t001w-werks.

    IF iv_werks IS INITIAL.
      RETURN.
    ENDIF.

    SELECT SINGLE werks
      INTO @lv_werks
      FROM t001w
      WHERE werks = @iv_werks.

    IF sy-subrc <> 0.
      MESSAGE text-e03 TYPE 'E'.
    ENDIF.
  ENDMETHOD.

  " Steps 5a-5g: Data retrieval and processing
  METHOD get_data.
    CLEAR: gt_raw, gt_t001w, gt_final.

    " Step 5a: Plant filter handled via OR condition in WHERE clause
    " (Alternative to creating RSELOPTION internal table)

    " Step 5b: INNER JOIN MARA and MCHA on MATNR (primary key = foreign key)
    " Filter with screen criteria material, created on, and plant
    " Note: a~brgew, a~ntgew, a~gewei, a~volum, a~voleh come from MARA
    " (instructions say MCHA but verified in SE11 they are in MARA)
    SELECT a~matnr,
           a~mtart,
           a~matkl,
           a~mbrsh,
           a~brgew,
           a~ntgew,
           a~gewei,
           a~volum,
           a~voleh,
           b~werks,
           b~charg,
           b~ersda,
           b~ernam,
           b~laeda,
           b~aenam,
           b~bwtar,
           b~lifnr,
           b~lwedt,
           b~herkl
      FROM mara AS a
      INNER JOIN mcha AS b
        ON a~matnr = b~matnr
      WHERE a~matnr IN @it_matnr
        AND b~ersda IN @it_ersda
        AND ( b~werks = @iv_werks OR @iv_werks IS INITIAL )
      INTO TABLE @gt_raw.

    " Step 5b: Sort by primary keys
    SORT gt_raw BY matnr werks charg ersda.

    " Step 5b: No data found -> error message + LEAVE LIST-PROCESSING
    IF gt_raw IS INITIAL.
      MESSAGE text-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.

    " Missing: Step 5d - FOR ALL ENTRIES into MAKT
    " Should get MATNR, MAKTX from MAKT with SPRAS = SY-LANGU
    " Needed for concatenating Material - Description in Column 1

    " Step 5e: FOR ALL ENTRIES into T001W for plant names
    " Missing: SPRAS = SY-LANGU filter (T001W may not have SPRAS in this system)
    SELECT werks,
           name1
      INTO TABLE @gt_t001w
      FROM t001w
      FOR ALL ENTRIES IN @gt_raw
      WHERE werks = @gt_raw-werks.

    " Sort by primary keys for BINARY SEARCH later
    SORT gt_t001w BY werks.

    " Step 5f: Build final output table
    build_final_output( iv_hili = iv_hili ).

    " Step 5c / 9j: Check if final table has entries
    IF gt_final IS INITIAL.
      MESSAGE text-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.
  ENDMETHOD.

  " Step 5f: LOOP and READ to transfer all fields into final table
  METHOD build_final_output.
    DATA: ls_raw   TYPE ty_raw,
          ls_final TYPE ty_final,
          ls_t001w TYPE ty_t001w,
          ls_scol  TYPE lvc_s_scol.

    LOOP AT gt_raw INTO ls_raw.
      CLEAR: ls_final, ls_t001w.

      " READ plant name from T001W using BINARY SEARCH
      READ TABLE gt_t001w INTO ls_t001w
        WITH KEY werks = ls_raw-werks
        BINARY SEARCH.

      " Missing: READ TABLE from MAKT for material description
      " Missing: Concatenate Material - Description with dash
      " Currently only shows MATNR, should show "MATNR - MAKTX"

      ls_final-material        = ls_raw-matnr.
      ls_final-plant           = ls_raw-werks.
      ls_final-plant_name      = ls_t001w-name1.
      ls_final-batch           = ls_raw-charg.
      ls_final-created_on      = lcl_util=>format_date_mdy( ls_raw-ersda ).
      ls_final-created_by      = ls_raw-ernam.
      ls_final-changed_on      = lcl_util=>format_date_mdy( ls_raw-laeda ).
      ls_final-changed_by      = ls_raw-aenam.
      ls_final-material_type   = ls_raw-mtart.
      ls_final-valuation_type  = ls_raw-bwtar.
      ls_final-material_group  = ls_raw-matkl.
      ls_final-industry_sector = ls_raw-mbrsh.
      ls_final-gross_weight    = ls_raw-brgew.
      ls_final-net_weight      = ls_raw-ntgew.
      ls_final-unit_weight     = ls_raw-gewei.
      ls_final-volume          = ls_raw-volum.
      ls_final-volume_unit     = ls_raw-voleh.
      ls_final-supplier        = ls_raw-lifnr.
      ls_final-goods_receipt   = lcl_util=>format_date_mdy( ls_raw-lwedt ).
      ls_final-country         = ls_raw-herkl.

      " Step 9e: GREEN color for Material column
      IF iv_hili = abap_true.
        CLEAR ls_scol.
        ls_scol-fname = 'MATERIAL'.
        ls_scol-color-col = 5.       " 5 = Green
        ls_scol-color-int = 1.
        ls_scol-color-inv = 0.
        APPEND ls_scol TO ls_final-cell_color.
      ENDIF.

      APPEND ls_final TO gt_final.
    ENDLOOP.

    " Step 9h: Sort criteria (partially correct)
    " Missing: ERSDA 4 DESC sort
    SORT gt_final BY material ASCENDING    " 1 ASC - correct
                     plant ASCENDING       " 2 ASC - correct
                     batch ASCENDING.      " 3 ASC - correct
  ENDMETHOD.

ENDCLASS.

************************************************************************
* Step 9c: Event Handler Implementation
* When Material is clicked -> SET PARAMETER ID 'MAT' ->
* CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN
************************************************************************
CLASS lcl_event_handler IMPLEMENTATION.
  METHOD on_link_click.
    READ TABLE lcl_model=>gt_final INTO DATA(ls_final) INDEX row.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    " Missing: Should check column = 'MATERIAL' without also checking p_hili
    " The hotspot should only be enabled/disabled at ALV setup time,
    " not re-checked at click time. Also p_hili is a global variable
    " being accessed inside a method (violates Rule #6).
    IF column = 'MATERIAL' AND p_hili = 'X'.
      SET PARAMETER ID 'MAT' FIELD ls_final-material.
      CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
    ENDIF.
  ENDMETHOD.
ENDCLASS.

************************************************************************
* Step 7: View Class Implementation
************************************************************************
CLASS lcl_view IMPLEMENTATION.

  " Step 7: WRITE display method
  " 7c: Write column headers/descriptions first before writing data
  METHOD display_write.
    DATA: ls_final     TYPE ty_final,
          lv_exec_date TYPE char10,
          lv_exec_time TYPE char8.

    lv_exec_date = lcl_util=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_util=>format_time_military( sy-uzeit ).

    " Step 9b heading (also applies to WRITE view)
    WRITE: / text-h01.
    WRITE: / text-h02.
    WRITE: / 'Executed by:', sy-uname.
    " Missing: Dash separator between date and time
    " Should be: Executed on: MM/DD/YYYY - HH:MM:SS
    WRITE: / 'Executed on:', lv_exec_date, lv_exec_time.
    SKIP.

    " 7c + 9i: Column headers using text elements (not hardcoded)
    FORMAT COLOR COL_HEADING INTENSIFIED ON.
    WRITE: / text-c01,
             20 text-c02,
             32 text-c03,
             60 text-c04,
             75 text-c05,
             88 text-c06,
             102 text-c07,
             115 text-c08,
             128 text-c09,
             142 text-c10.
    WRITE: / text-c11,
             20 text-c12,
             38 text-c13,
             55 text-c14,
             72 text-c15,
             88 text-c16,
             104 text-c17,
             120 text-c18,
             136 text-c19,
             152 text-c20.
    FORMAT RESET.

    " Missing: Reads lcl_model=>gt_final directly instead of importing
    " via method parameter (violates Rule #6)
    LOOP AT lcl_model=>gt_final INTO ls_final.
      WRITE: / ls_final-material,
               20 ls_final-plant,
               32 ls_final-plant_name,
               60 ls_final-batch,
               75 ls_final-created_on,
               88 ls_final-created_by,
               102 ls_final-changed_on,
               115 ls_final-changed_by,
               128 ls_final-material_type,
               142 ls_final-valuation_type.
      WRITE: / ls_final-material_group,
               20 ls_final-industry_sector,
               38 ls_final-gross_weight,
               55 ls_final-net_weight,
               72 ls_final-unit_weight,
               88 ls_final-volume,
               104 ls_final-volume_unit,
               120 ls_final-supplier,
               136 ls_final-goods_receipt,
               152 ls_final-country.
      ULINE.
    ENDLOOP.
  ENDMETHOD.

  " Steps 7d + 9: ALV display using SALV
  " TRY CATCH ENDTRY to prevent runtime errors
  METHOD display_alv.
    DATA: lo_alv       TYPE REF TO cl_salv_table,
          lo_columns   TYPE REF TO cl_salv_columns_table,
          lo_column    TYPE REF TO cl_salv_column_table,
          lo_functions TYPE REF TO cl_salv_functions_list,
          lo_display   TYPE REF TO cl_salv_display_settings,
          lo_sorts     TYPE REF TO cl_salv_sorts,
          lo_header    TYPE REF TO cl_salv_form_layout_grid,
          lo_events    TYPE REF TO cl_salv_events_table,
          lo_handler   TYPE REF TO lcl_event_handler,
          lv_exec_date TYPE char10,
          lv_exec_time TYPE char8.

    lv_exec_date = lcl_util=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_util=>format_time_military( sy-uzeit ).

    TRY.
        " SALV factory (syntax from doc page 15)
        cl_salv_table=>factory(
          IMPORTING
            r_salv_table = lo_alv
          CHANGING
            t_table      = lcl_model=>gt_final ).

        lo_columns = lo_alv->get_columns( ).

        " 9f: Optimize column width
        TRY.
            lo_columns->set_optimize( ).
          CATCH cx_salv_data_error.
        ENDTRY.

        " 9e: Cell-level color support
        TRY.
            lo_columns->set_color_column( 'CELL_COLOR' ).
          CATCH cx_salv_data_error.
        ENDTRY.

        " 9i: Column descriptions in text elements (C01-C20)
        " 9c: Hotspot on Material column (when checkbox marked)
        " 9e: GREEN color handled via cell_color field
        TRY.
            lo_column ?= lo_columns->get_column( 'MATERIAL' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c01 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c01 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c01 ) ).
            " 9c: Hotspot only when checkbox is marked
            " Missing: p_hili is global variable accessed inside method (Rule #6)
            IF p_hili = 'X'.
              lo_column->set_cell_type( if_salv_c_cell_type=>hotspot ).
            ENDIF.
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        " Columns 2-20: Set text element descriptions
        TRY.
            lo_column ?= lo_columns->get_column( 'PLANT' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c02 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c02 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c02 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'PLANT_NAME' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c03 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c03 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c03 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'BATCH' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c04 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c04 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c04 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'CREATED_ON' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c05 ) ).
